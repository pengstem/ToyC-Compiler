      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TOYCC_ENABLE_WARNINGS": "ON",
        "TOYCC_WARNINGS_AS_ERRORS": "OFF",
        "TOYCC_ENABLE_SANITIZERS": "OFF",
        "TOYCC_ENABLE_LTO": "OFF",
        "TOYCC_BUILD_TESTS": "ON",
        "TOYCC_ENABLE_IMPORTED_TESTS": "ON"
      }
    },
    {
      "name": "sanitize",
      "displayName": "Sanitize",
      "description": "Debug build with AddressSanitizer and UBSan",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/sanitize",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TOYCC_ENABLE_WARNINGS": "ON",
        "TOYCC_WARNINGS_AS_ERRORS": "OFF",
        "TOYCC_ENABLE_SANITIZERS": "ON",
        "TOYCC_ENABLE_LTO": "OFF",
        "TOYCC_BUILD_TESTS": "ON",
        "TOYCC_ENABLE_IMPORTED_TESTS": "ON"
      }
    },
    {
      "name": "strict",
      "displayName": "Strict",
      "description": "Debug build with warnings as errors",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/strict",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TOYCC_ENABLE_WARNINGS": "ON",
        "TOYCC_WARNINGS_AS_ERRORS": "ON",
        "TOYCC_ENABLE_SANITIZERS": "OFF",
        "TOYCC_ENABLE_LTO": "OFF",
        "TOYCC_BUILD_TESTS": "ON",
        "TOYCC_ENABLE_IMPORTED_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
